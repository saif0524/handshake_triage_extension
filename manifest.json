{
  "manifest_version": 3,
  "name": "Handshake Message Triage Assistant",
  "description": "Prototype Chrome extension that classifies visible Handshake messages and drafts local rule-based replies.",
  "version": "1.0.0",
  "action": {
    "default_title": "Handshake Triage",
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.joinhandshake.com/*",
        "https://joinhandshake.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://*.joinhandshake.com/*",
    "https://joinhandshake.com/*"
  ]
}
